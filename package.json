{
  "name": "@d-i-t-a/reader",
  "version": "2.5.0",
  "description": "A viewer application for EPUB files.",
  "repository": "https://github.com/d-i-t-a/R2D2BC",
  "license": "Apache-2.0",
  "main": "dist/esm/index.js",
  "typings": "dist/types/index.d.ts",
  "targets": {
    "main": false
  },
  "engines": {
    "node": ">=16"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepare": "npm run build",
    "clean": "rimraf node_modules dist parcel-dist .parcel-cache",
    "dev": "ts-node -T build.ts -w",
    "build": "ts-node -T build.ts",
    "sass:debug": "sass --source-map src/styles/sass/:dist",
    "sass:release": "sass --style=compressed src/styles/sass/:dist",
    "examples": "npx ts-node examples/server.ts",
    "lint": "eslint '*/**/*.{js,ts,tsx}' --fix",
    "example:clean": "rm -rf parcel-dist .parcel-cache",
    "example:react": "npm run example:clean && parcel examples/react/index.html --dist-dir parcel-dist",
    "example:vue": "npm run example:clean && parcel examples/vue/index.html --dist-dir parcel-dist --no-hmr",
    "example:angular": "npm run example:clean && parcel examples/angular/index.html --dist-dir parcel-dist",
    "example:nextjs": "npm run example:clean && parcel examples/nextjs/index.html --dist-dir parcel-dist",
    "example:remix": "npm run example:clean && parcel examples/remix/index.html --dist-dir parcel-dist",
    "example:pdf": "npm run build && npx ts-node examples/pdf/serve.ts",
    "example:vanilla": "npm run build && npx ts-node examples/vanilla/serve.ts",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "browserslist-useragent-regexp": "^4.1.0",
    "cssesc": "^3.0.0",
    "debounce": "^2.0.0",
    "devtools-detector": "^2.0.14",
    "eventemitter3": "^5.0.1",
    "jscrypto": "^1.0.3",
    "lodash": "^4.17.21",
    "loglevel": "^1.8.0",
    "pdfjs-dist": "^5.5.207",
    "r2-shared-js": "^1.0.82",
    "recursive-readdir": "^2.2.2",
    "sanitize-html": "^2.3.3",
    "ta-json-x": "^2.5.3",
    "util": "^0.12.4",
    "uuid": "^11.0.0"
  },
  "browserslist": {
    "production": [
      "last 1 chrome version",
      "last 1 safari version",
      "last 1 edge version"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 safari version",
      "last 1 edge version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@parcel/transformer-sass": "^2.7.0",
    "@parcel/transformer-typescript-tsc": "^2.7.0",
    "@parcel/transformer-vue": "^2.16.4",
    "@types/copy": "^0.3.1",
    "@types/cssesc": "^3.0.0",
    "@types/debounce": "^3.0.0",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.0",
    "@types/react": "^18.2.31",
    "@types/react-dom": "^18.2.14",
    "@types/rimraf": "^4.0.5",
    "@types/sanitize-html": "^2.13.0",
    "@types/sass": "^1.43.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "ansi-regex": ">=5.0.1",
    "babel-eslint": "^10.1.0",
    "braces": ">=3.0.2",
    "buffer": "^6.0.3",
    "chalk": "^4.1.2",
    "chokidar": "^4.0.1",
    "copy": "^0.3.2",
    "r2-streamer-js": "^1.0.51",
    "esbuild": "^0.27.2",
    "eslint": "^8.52.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-flowtype": "^8.0.3",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "express": "^5.2.1",
    "json-schema": ">=0.4.0",
    "parcel": "^2.7.0",
    "parcel-config-precache-manifest": "^0.0.4",
    "parcel-plugin-static-files-copy": "^2.6.0",
    "parcel-reporter-static-files-copy": "^1.4.0",
    "prettier": "^3.3.3",
    "process": "^0.11.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^6.0.1",
    "sass": "^1.54.4",
    "tar": ">=6.1.9",
    "ts-node": "^10.9.1",
    "typedoc": "^0.28.15",
    "typedoc-plugin-rename-defaults": "^0.7.3",
    "typescript": "5.9.3",
    "vitest": "^4.0.18",
    "vue": "^3.5.30"
  },
  "files": [
    "dist"
  ],
  "resolutions": {
    "braces": "3.0.3"
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": false,
    "trailingComma": "es5"
  },
  "@parcel/resolver-default": {
    "packageExports": true
  }
}
